{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",
    "moduleResolution": "node",

    "outDir": "./dist",
    "baseUrl": "./",

    "sourceMap": true,
    "incremental": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "strict": true,
    "skipLibCheck": true
  }
}